---
permalink: /search.json
---
[
  {% assign output_items = "" | split: "" %}
  
  {% for post in site.posts %}
    {% capture post_json %}
    {
      "title": {{ post.title | jsonify }},
      "category": "Post",
      "url": {{ post.url | relative_url | jsonify }},
      "date": {{ post.date | date: "%Y-%m-%d" | jsonify }}
    }
    {% endcapture %}
    {% assign output_items = output_items | push: post_json %}
  {% endfor %}

  {% for page in site.pages %}
    {% if page.title and page.url != '/' and page.url != '/404.html' and page.url != '/search.json' %}
      {% capture page_json %}
      {
        "title": {{ page.title | jsonify }},
        "category": "Page",
        "url": {{ page.url | relative_url | jsonify }},
        "date": "Static"
      }
      {% endcapture %}
      {% assign output_items = output_items | push: page_json %}
    {% endif %}
  {% endfor %}

  {% for json_string in output_items %}
    {{ json_string }}{% unless forloop.last %},{% endunless %}
  {% endfor %}
]

